# ==============================================================================
# MergeMinD — Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# Firebase (Email Authentication — free Spark plan)
# Get from: console.firebase.google.com → Project Settings → Your Apps
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="your_firebase_app_id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your_measurement_id_here"

# ------------------------------------------------------------------------------
# Gemini AI (free — 1M tokens/day)
# Get from: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key_here"

# ------------------------------------------------------------------------------
# GitLab (free account)
# Token from: https://gitlab.com/-/user_settings/personal_access_tokens
# Scope required: api
# ------------------------------------------------------------------------------
GITLAB_PERSONAL_ACCESS_TOKEN="your_gitlab_personal_access_token_here"
GITLAB_API_URL="https://gitlab.com"

# ------------------------------------------------------------------------------
# GitLab MCP Server (free with 30-day Ultimate trial)
# Activate trial: https://about.gitlab.com/free-trial/
# No installation needed — hosted by GitLab at this URL
# ------------------------------------------------------------------------------
GITLAB_MCP_URL="https://gitlab.com/api/v4/mcp"
