# ==============================================================================
# MergeMinD v3 Environment Variables Example Template
# ==============================================================================
# Copy this file to a new file named `.env` and fill in your actual values.
# DO NOT commit the `.env` file containing your real secret keys.

# ------------------------------------------------------------------------------
# 1. Firebase Client-Side Web Configuration (Email Authentication)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abcdef123456"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-ABC123XYZ"

# ------------------------------------------------------------------------------
# 2. Gemini AI Configuration (AI-Powered Code Review Engine)
# ------------------------------------------------------------------------------
GEMINI_API_KEY="AIzaSy..."

# ------------------------------------------------------------------------------
# 3. GitLab Integration & MCP Server Configuration
# ------------------------------------------------------------------------------
# GitLab Personal Access Token (PAT) with 'api' scope:
GITLAB_PERSONAL_ACCESS_TOKEN="glpat-..."

# The base URL of your GitLab instance (defaults to https://gitlab.com if empty)
GITLAB_API_URL="https://gitlab.com"

# ------------------------------------------------------------------------------
# 4. Google Cloud Dialogflow CX / Vertex AI Agent Builder (Optional)
# ------------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID="your-gcp-project-id"
AGENT_BUILDER_AGENT_ID="your-agent-builder-agent-id"
AGENT_BUILDER_LOCATION="us-central1"

# Service Account credentials file parsed as a flattened single-line JSON string:
GOOGLE_SERVICE_ACCOUNT_KEY=""

# Alternatively, a raw Access Token can be provided directly for local developer testing:
GOOGLE_ACCESS_TOKEN=""
